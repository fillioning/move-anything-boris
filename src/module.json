{
  "id": "granular",
  "name": "Boris Granular",
  "abbrev": "GRAN",
  "version": "0.1.0",
  "description": "Real-time granular FX with live input capture",
  "author": "Boris (port: charlesvestal)",
  "license": "GPL-3.0",
  "dsp": "granular.so",
  "api_version": 2,
  "capabilities": {
    "chainable": true,
    "component_type": "audio_fx",
    "ui_hierarchy": {
      "modes": ["Granular", "Randomize", "Sync", "Advanced"],
      "levels": {
        "Granular": {
          "label": "Granular",
          "params": [
            {
              "key": "density",
              "label": "Density",
              "type": "float",
              "min": 0.04,
              "max": 1.0,
              "default": 0.52,
              "step": 0.01
            },
            {
              "key": "grain_size",
              "label": "Size",
              "type": "float",
              "min": 20.0,
              "max": 2000.0,
              "default": 200.0,
              "step": 1,
              "unit": "ms"
            },
            {
              "key": "pitch",
              "label": "Pitch Shift",
              "type": "float",
              "min": 0.25,
              "max": 4.0,
              "default": 1.0,
              "step": 0.01
            },
            {
              "key": "envelope",
              "label": "Envelope",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.0,
              "step": 0.01
            },
            {
              "key": "position",
              "label": "Position",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.0,
              "step": 0.01
            },
            {
              "key": "drift",
              "label": "Drift",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.0,
              "step": 0.01
            },
            {
              "key": "wet",
              "label": "Wet",
              "type": "float",
              "min": 0.0,
              "max": 1.5,
              "default": 1.0,
              "step": 0.01
            },
            {
              "key": "freeze",
              "label": "Freeze",
              "type": "enum",
              "options": ["off", "on"],
              "default": 0
            }
          ],
          "knobs": [
            "density",
            "grain_size",
            "pitch",
            "envelope",
            "position",
            "drift",
            "wet",
            "freeze"
          ]
        },
        "Randomize": {
          "label": "Randomize",
          "params": [
            {
              "key": "random_length",
              "label": "Rdm Size",
              "type": "float",
              "min": 0.0,
              "max": 100.0,
              "default": 0.0,
              "step": 1,
              "unit": "%"
            },
            {
              "key": "random_delay",
              "label": "Rdm Delay",
              "type": "float",
              "min": 0.0,
              "max": 100.0,
              "default": 0.0,
              "step": 1,
              "unit": "%"
            },
            {
              "key": "random_pitch",
              "label": "Rdm Shift",
              "type": "float",
              "min": 0.0,
              "max": 100.0,
              "default": 0.0,
              "step": 1,
              "unit": "%"
            },
            {
              "key": "reverse_prob",
              "label": "Reverse",
              "type": "float",
              "min": 0.0,
              "max": 100.0,
              "default": 0.0,
              "step": 1,
              "unit": "%"
            },
            {
              "key": "pan_width",
              "label": "Pan Width",
              "type": "float",
              "min": 0.0,
              "max": 100.0,
              "default": 0.0,
              "step": 1,
              "unit": "%"
            },
            {
              "key": "random_vol",
              "label": "Rdm Vol",
              "type": "float",
              "min": 0.0,
              "max": 100.0,
              "default": 0.0,
              "step": 1,
              "unit": "%"
            },
            {
              "key": "chance",
              "label": "Chance",
              "type": "float",
              "min": 0.0,
              "max": 100.0,
              "default": 100.0,
              "step": 1,
              "unit": "%"
            },
            {
              "key": "feedback",
              "label": "Feedback",
              "type": "float",
              "min": 0.0,
              "max": 90.0,
              "default": 0.0,
              "step": 1,
              "unit": "%"
            }
          ],
          "knobs": [
            "random_length",
            "random_delay",
            "random_pitch",
            "reverse_prob",
            "pan_width",
            "random_vol",
            "chance",
            "feedback"
          ]
        },
        "Sync": {
          "label": "Sync",
          "params": [
            {
              "key": "sync",
              "label": "Sync",
              "type": "enum",
              "options": ["off", "on"],
              "default": 0
            },
            {
              "key": "division",
              "label": "Division",
              "type": "enum",
              "options": ["1/16", "1/8", "1/4", "1/2", "1/1", "2/1", "4/1"],
              "default": 3
            },
            {
              "key": "rhythm",
              "label": "Rhythm",
              "type": "enum",
              "options": ["normal", "dotted", "triplet"],
              "default": 0
            }
          ],
          "knobs": [
            "sync",
            "division",
            "rhythm"
          ]
        },
        "Advanced": {
          "label": "Advanced",
          "params": [
            {
              "key": "gain",
              "label": "Input",
              "type": "float",
              "min": 0.0,
              "max": 1.5,
              "default": 1.0,
              "step": 0.01
            },
            {
              "key": "dry",
              "label": "Dry",
              "type": "float",
              "min": 0.0,
              "max": 1.5,
              "default": 1.0,
              "step": 0.01
            },
            {
              "key": "mute",
              "label": "Mute",
              "type": "enum",
              "options": ["off", "on"],
              "default": 0
            },
            {
              "key": "voice_count",
              "label": "Voices",
              "type": "int",
              "min": 1,
              "max": 24,
              "default": 24,
              "step": 1
            }
          ],
          "knobs": [
            "gain",
            "dry",
            "mute",
            "voice_count"
          ]
        }
      }
    }
  }
}
