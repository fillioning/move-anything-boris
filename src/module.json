{
  "id": "granular",
  "name": "Boris Granular",
  "abbrev": "GRAN",
  "version": "0.3.0",
  "description": "Real-time granular FX with live input capture",
  "author": "Boris (port: charlesvestal)",
  "license": "GPL-3.0",
  "dsp": "granular.so",
  "api_version": 2,
  "capabilities": {
    "chainable": true,
    "component_type": "audio_fx",
    "ui_hierarchy": {
      "modes": null,
      "levels": {
        "root": {
          "name": "Boris Granular",
          "knobs": ["density", "grain_size", "position", "pitch", "feedback", "pan_width", "freeze", "mix"],
          "params": [
            {"level": "Granular", "label": "Granular"},
            {"level": "Randomize", "label": "Randomize"},
            {"level": "Sync", "label": "Sync"},
            {"level": "Advanced", "label": "Advanced"}
          ]
        },
        "Granular": {
          "label": "Granular",
          "knobs": ["density", "grain_size", "position", "pitch", "feedback", "pan_width", "freeze", "mix"],
          "params": [
            {"key": "density", "label": "Density", "type": "float", "min": 0.04, "max": 1.0, "default": 0.5, "step": 0.01},
            {"key": "grain_size", "label": "Size", "type": "float", "min": 20.0, "max": 2000.0, "default": 200.0, "step": 1, "unit": "ms"},
            {"key": "position", "label": "Position", "type": "float", "min": 0.0, "max": 1.0, "default": 0.0, "step": 0.01},
            {"key": "pitch", "label": "Pitch Shift", "type": "float", "min": 0.25, "max": 4.0, "default": 1.0, "step": 0.01},
            {"key": "feedback", "label": "Feedback", "type": "float", "min": 0.0, "max": 90.0, "default": 0.0, "step": 1, "unit": "%"},
            {"key": "pan_width", "label": "Pan Width", "type": "float", "min": 0.0, "max": 100.0, "default": 50.0, "step": 1, "unit": "%"},
            {"key": "freeze", "label": "Freeze", "type": "enum", "options": ["off", "on"], "default": 0},
            {"key": "mix", "label": "Dry/Wet", "type": "float", "min": 0.0, "max": 100.0, "default": 50.0, "step": 1, "unit": "%"},
            {"key": "envelope", "label": "Envelope", "type": "float", "min": 0.0, "max": 1.0, "default": 0.0, "step": 0.01},
            {"key": "drift", "label": "Drift", "type": "float", "min": 0.0, "max": 1.0, "default": 0.0, "step": 0.01}
          ]
        },
        "Randomize": {
          "label": "Randomize",
          "knobs": ["random_length", "random_delay", "random_pitch", "reverse_prob", "random_vol", "chance"],
          "params": [
            {"key": "random_length", "label": "Rdm Size", "type": "float", "min": 0.0, "max": 100.0, "default": 0.0, "step": 1, "unit": "%"},
            {"key": "random_delay", "label": "Rdm Delay", "type": "float", "min": 0.0, "max": 100.0, "default": 0.0, "step": 1, "unit": "%"},
            {"key": "random_pitch", "label": "Rdm Shift", "type": "float", "min": 0.0, "max": 100.0, "default": 0.0, "step": 1, "unit": "%"},
            {"key": "reverse_prob", "label": "Reverse", "type": "float", "min": 0.0, "max": 100.0, "default": 0.0, "step": 1, "unit": "%"},
            {"key": "random_vol", "label": "Rdm Vol", "type": "float", "min": 0.0, "max": 100.0, "default": 0.0, "step": 1, "unit": "%"},
            {"key": "chance", "label": "Chance", "type": "float", "min": 0.0, "max": 100.0, "default": 100.0, "step": 1, "unit": "%"}
          ]
        },
        "Sync": {
          "label": "Sync",
          "knobs": ["sync", "division", "rhythm"],
          "params": [
            {"key": "sync", "label": "Sync", "type": "enum", "options": ["off", "on"], "default": 0},
            {"key": "division", "label": "Division", "type": "enum", "options": ["1/16", "1/8", "1/4", "1/2", "1/1", "2/1", "4/1"], "default": 3},
            {"key": "rhythm", "label": "Rhythm", "type": "enum", "options": ["normal", "dotted", "triplet"], "default": 0}
          ]
        },
        "Advanced": {
          "label": "Advanced",
          "knobs": ["gain", "mute", "voice_count"],
          "params": [
            {"key": "gain", "label": "Input", "type": "float", "min": 0.0, "max": 1.5, "default": 1.0, "step": 0.01},
            {"key": "mute", "label": "Mute", "type": "enum", "options": ["off", "on"], "default": 0},
            {"key": "voice_count", "label": "Voices", "type": "int", "min": 1, "max": 24, "default": 24, "step": 1}
          ]
        }
      }
    }
  }
}
